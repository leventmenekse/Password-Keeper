<Application x:Class="PasswordKeeper.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PasswordKeeper.App.Infrastructure.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Theme.Dark.xaml" />
                <ResourceDictionary Source="Resources/Icons.xaml" />
                <ResourceDictionary Source="Resources/Styles.Controls.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
            <conv:InverseBoolConverter x:Key="InverseBool" />
            <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
            <conv:TitleToInitialConverter x:Key="TitleToInitial" />
            <conv:TitleToBackgroundBrushConverter x:Key="TitleToBg" />
            <conv:TitleToForegroundBrushConverter x:Key="TitleToFg" />
            <conv:RelativeTimeConverter x:Key="RelativeTime" />
            <conv:PasswordMaskConverter x:Key="PasswordMask" />
            <conv:StrengthCellBrushConverter x:Key="StrengthCellBrush" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
