<Window x:Class="PasswordKeeper.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:vm="clr-namespace:PasswordKeeper.App.ViewModels"
        Title="PasswordKeeper"
        Icon="pack://application:,,,/Resources/Icons/PasswordKeeper.ico"
        Height="780" Width="1280"
        MinHeight="560" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Brush.Bg}">

    <Window.Resources>
        <!-- Reusable: icon Path defaults -->
        <Style x:Key="Icon14" TargetType="Path">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
            <Setter Property="Stretch" Value="Uniform" />
            <Setter Property="StrokeThickness" Value="1.5" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="StrokeLineJoin" Value="Round" />
        </Style>
        <Style x:Key="Icon12" TargetType="Path" BasedOn="{StaticResource Icon14}">
            <Setter Property="Width" Value="12" />
            <Setter Property="Height" Value="12" />
        </Style>

        <sys:Int32 x:Key="Idx0">0</sys:Int32>
        <sys:Int32 x:Key="Idx1">1</sys:Int32>
        <sys:Int32 x:Key="Idx2">2</sys:Int32>
        <sys:Int32 x:Key="Idx3">3</sys:Int32>
        <sys:Int32 x:Key="Idx4">4</sys:Int32>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══════ Toolbar ═══════ -->
        <Border Grid.Row="0"
                Height="44"
                Background="{DynamicResource Brush.Panel}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False" Margin="12,0">

                <Button DockPanel.Dock="Left" Style="{StaticResource Btn.Primary}" Margin="0,0,6,0"
                        Command="{Binding AddEntryCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource Icon12}"
                              Data="{StaticResource Icon.Plus}"
                              Stroke="White" />
                        <TextBlock Text="New entry" Margin="7,0,0,0" Foreground="White" />
                    </StackPanel>
                </Button>

                <Button DockPanel.Dock="Left" Style="{StaticResource Btn.Default}" Margin="0,0,6,0"
                        Command="{Binding AddCategoryCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource Icon12}"
                              Data="{StaticResource Icon.Plus}"
                              Stroke="{DynamicResource Brush.Text}" />
                        <TextBlock Text="Category" Margin="7,0,0,0" />
                    </StackPanel>
                </Button>

                <Border DockPanel.Dock="Left" Width="1" Height="18"
                        Background="{DynamicResource Brush.Border}" Margin="4,0" />

                <Button DockPanel.Dock="Left" Style="{StaticResource Btn.Ghost}" Click="OnRenameCategoryClick"
                        Content="Rename" />
                <Button DockPanel.Dock="Left" Style="{StaticResource Btn.Danger}"
                        Command="{Binding DeleteCategoryCommand}"
                        Content="Delete" />

                <!-- Right side -->
                <Button DockPanel.Dock="Right" Style="{StaticResource Btn.Ghost}"
                        Command="{Binding LockCommand}" Margin="6,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource Icon12}"
                              Data="{StaticResource Icon.Lock}"
                              Stroke="{DynamicResource Brush.Text2}" />
                        <TextBlock Text="Lock" Margin="7,0,0,0" Foreground="{DynamicResource Brush.Text2}" />
                    </StackPanel>
                </Button>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center"
                            Margin="0,0,10,0">
                    <Ellipse Width="7" Height="7" Fill="{DynamicResource Brush.Good}" Margin="0,0,6,0" />
                    <TextBlock Text="unlocked · " Foreground="{DynamicResource Brush.Muted}"
                               FontFamily="{DynamicResource Font.Mono}" FontSize="11" />
                    <TextBlock Text="{Binding TotalEntryCount}" Foreground="{DynamicResource Brush.Muted}"
                               FontFamily="{DynamicResource Font.Mono}" FontSize="11" />
                    <TextBlock Text=" entries" Foreground="{DynamicResource Brush.Muted}"
                               FontFamily="{DynamicResource Font.Mono}" FontSize="11" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══════ Body ═══════ -->
        <Grid Grid.Row="1" Background="{DynamicResource Brush.Bg}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ───── Sidebar ───── -->
            <Border Grid.Column="0"
                    BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,1,0">
                <DockPanel Margin="6,14,6,14">
                    <TextBlock DockPanel.Dock="Top"
                               Style="{StaticResource Text.Caption}"
                               Text="CATEGORIES"
                               Margin="10,0,10,8" />

                    <ListBox x:Name="CategoriesListBox"
                             Style="{StaticResource ListBox.Flat}"
                             ItemContainerStyle="{StaticResource ListBoxItem.Sidebar}"
                             ItemsSource="{Binding CategoryItems}"
                             SelectedItem="{Binding SelectedCategoryItem, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="8,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="14" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="›"
                                               FontFamily="{DynamicResource Font.Mono}"
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource Brush.Accent}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <TextBox Grid.Column="1"
                                             Text="{Binding Name, UpdateSourceTrigger=LostFocus}"
                                             FontSize="12.5"
                                             VerticalAlignment="Center"
                                             LostFocus="OnCategoryNameLostFocus"
                                             KeyDown="OnCategoryNameKeyDown">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="IsReadOnly" Value="True" />
                                                <Setter Property="IsHitTestVisible" Value="False" />
                                                <Setter Property="Focusable" Value="False" />
                                                <Setter Property="BorderThickness" Value="0" />
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="Foreground" Value="{DynamicResource Brush.Text2}" />
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="Margin" Value="0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource Brush.Text}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                        <Setter Property="IsReadOnly" Value="False" />
                                                        <Setter Property="IsHitTestVisible" Value="True" />
                                                        <Setter Property="Focusable" Value="True" />
                                                        <Setter Property="BorderThickness" Value="1" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border2}" />
                                                        <Setter Property="Background" Value="{DynamicResource Brush.Panel2}" />
                                                        <Setter Property="Padding" Value="4,1" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Count}"
                                               FontFamily="{DynamicResource Font.Mono}"
                                               FontSize="10.5"
                                               Foreground="{DynamicResource Brush.Muted}"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- ───── List ───── -->
            <Border Grid.Column="1"
                    BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Search row -->
                    <Border DockPanel.Dock="Top"
                            BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1"
                            Padding="14,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Style="{StaticResource Icon14}"
                                  Data="{StaticResource Icon.Search}"
                                  Stroke="{DynamicResource Brush.Muted}"
                                  Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="{DynamicResource Font.Mono}"
                                     FontSize="12.5"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="0"
                                     VerticalAlignment="Center">
                                <TextBox.Template>
                                    <ControlTemplate TargetType="TextBox">
                                        <Grid>
                                            <TextBlock x:Name="ph" Text="search entries…"
                                                       Foreground="{DynamicResource Brush.Dim}"
                                                       VerticalAlignment="Center"
                                                       Visibility="Collapsed" />
                                            <ScrollViewer x:Name="PART_ContentHost"
                                                          VerticalAlignment="Center" />
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter TargetName="ph" Property="Visibility" Value="Visible" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </TextBox.Template>
                            </TextBox>
                            <Border Grid.Column="2"
                                    Background="{DynamicResource Brush.Panel2}"
                                    BorderBrush="{DynamicResource Brush.Border}"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Padding="5,1">
                                <TextBlock Text="/" Foreground="{DynamicResource Brush.Muted}"
                                           FontFamily="{DynamicResource Font.Mono}" FontSize="10" />
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Result-count header -->
                    <Grid DockPanel.Dock="Top" Margin="14,8,14,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource Text.Caption}"
                                       Text="{Binding FilteredEntries.Count, StringFormat={}{0} ENTRIES}" />
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Style="{StaticResource Text.Caption}"
                                   Text="SORT: TITLE ↓" />
                    </Grid>

                    <!-- Entries -->
                    <ListBox Style="{StaticResource ListBox.Flat}"
                             ItemContainerStyle="{StaticResource ListBoxItem.Entry}"
                             ItemsSource="{Binding FilteredEntries}"
                             SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                             Margin="6,0,6,8">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="10,7">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Width="28" Height="28"
                                            CornerRadius="6"
                                            Background="{Binding Title, Converter={StaticResource TitleToBg}}"
                                            BorderBrush="{DynamicResource Brush.Border}"
                                            BorderThickness="1">
                                        <TextBlock Text="{Binding Title, Converter={StaticResource TitleToInitial}}"
                                                   Foreground="{Binding Title, Converter={StaticResource TitleToFg}}"
                                                   FontFamily="{DynamicResource Font.Mono}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="10,0,8,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Username}"
                                                   FontFamily="{DynamicResource Font.Mono}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource Brush.Muted}"
                                                   Margin="0,2,0,0"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding UpdatedAt, Converter={StaticResource RelativeTime}}"
                                               FontFamily="{DynamicResource Font.Mono}"
                                               FontSize="10.5"
                                               Foreground="{DynamicResource Brush.Dim}"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- ───── Detail ───── -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto"
                          Background="{DynamicResource Brush.Bg}">
                <Grid DataContext="{Binding EntryDetail}">
                    <!-- Entry view -->
                    <StackPanel Visibility="{Binding HasEntry, Converter={StaticResource BoolToVis}}">
                        <!-- Header -->
                        <Border BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1"
                                Padding="26,20,26,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Width="40" Height="40" CornerRadius="8"
                                        Background="{Binding Title, Converter={StaticResource TitleToBg}}"
                                        BorderBrush="{DynamicResource Brush.Border}"
                                        BorderThickness="1">
                                    <TextBlock Text="{Binding Title, Converter={StaticResource TitleToInitial}}"
                                               Foreground="{Binding Title, Converter={StaticResource TitleToFg}}"
                                               FontFamily="{DynamicResource Font.Mono}"
                                               FontSize="16" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource Text.Title}"
                                               Text="{Binding Title}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,0,2" />
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="edited "
                                                   FontFamily="{DynamicResource Font.Mono}" FontSize="11"
                                                   Foreground="{DynamicResource Brush.Muted}" />
                                        <TextBlock Text="{Binding UpdatedAt, Converter={StaticResource RelativeTime}}"
                                                   FontFamily="{DynamicResource Font.Mono}" FontSize="11"
                                                   Foreground="{DynamicResource Brush.Muted}" />
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                    <Button Style="{StaticResource Btn.Danger}" Command="{Binding DeleteCommand}"
                                            Padding="8,0" MinHeight="28">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Style="{StaticResource Icon14}"
                                                  Data="{StaticResource Icon.Trash}"
                                                  Stroke="{DynamicResource Brush.Accent}" />
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource Btn.Primary}" Command="{Binding SaveCommand}"
                                            Content="Save" MinWidth="80" Margin="6,0,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <StackPanel Margin="26,18,26,26">

                            <!-- Title field -->
                            <Border Style="{StaticResource Field.Card}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Text.CaptionLabel}" Text="TITLE" Margin="0,0,0,6" />
                                    <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                             Background="Transparent" BorderThickness="0" Padding="0"
                                             FontSize="13.5" />
                                </StackPanel>
                            </Border>

                            <!-- Username -->
                            <Border Style="{StaticResource Field.Card}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource Text.CaptionLabel}" Text="USERNAME" />
                                        <Button Grid.Column="1" Style="{StaticResource Btn.Mini}"
                                                Command="{Binding CopyUsernameCommand}">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Style="{StaticResource Icon12}"
                                                      Data="{StaticResource Icon.Copy}"
                                                      Stroke="{DynamicResource Brush.Muted}" />
                                                <TextBlock Text="copy" Margin="5,0,0,0" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                             Background="Transparent" BorderThickness="0" Padding="0"
                                             FontFamily="{DynamicResource Font.Mono}" FontSize="13" />
                                </StackPanel>
                            </Border>

                            <!-- Password -->
                            <Border Style="{StaticResource Field.Card}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource Text.CaptionLabel}" Text="PASSWORD" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Style="{StaticResource Btn.Mini}" Command="{Binding ToggleRevealCommand}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Style="{StaticResource Icon12}"
                                                          Data="{StaticResource Icon.Eye}"
                                                          Stroke="{DynamicResource Brush.Muted}" />
                                                    <TextBlock Margin="5,0,0,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="reveal" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsPasswordRevealed}" Value="True">
                                                                        <Setter Property="Text" Value="hide" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Button>
                                            <Button Style="{StaticResource Btn.Mini}" Command="{Binding CopyPasswordCommand}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Style="{StaticResource Icon12}"
                                                          Data="{StaticResource Icon.Copy}"
                                                          Stroke="{DynamicResource Brush.Muted}" />
                                                    <TextBlock Text="copy" Margin="5,0,0,0" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Reveal/hide: when revealed show editable TextBox; otherwise show masked TextBlock -->
                                    <Grid>
                                        <TextBlock FontFamily="{DynamicResource Font.Mono}" FontSize="16"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource Brush.Text}"
                                                   Visibility="{Binding IsPasswordRevealed, Converter={StaticResource InverseBoolToVis}}">
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource PasswordMask}">
                                                    <Binding Path="Password" />
                                                    <Binding Path="IsPasswordRevealed" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                                                 FontFamily="{DynamicResource Font.Mono}" FontSize="14"
                                                 Background="{DynamicResource Brush.Panel2}"
                                                 BorderBrush="{DynamicResource Brush.Border}"
                                                 Padding="6,4"
                                                 Visibility="{Binding IsPasswordRevealed, Converter={StaticResource BoolToVis}}" />
                                    </Grid>

                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <!-- Strength bar -->
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Width="28" Height="4" Margin="0,0,3,0" CornerRadius="2">
                                                <Border.Background>
                                                    <MultiBinding Converter="{StaticResource StrengthCellBrush}">
                                                        <Binding Path="PasswordStrength" />
                                                        <Binding Source="{StaticResource Idx0}" />
                                                    </MultiBinding>
                                                </Border.Background>
                                            </Border>
                                            <Border Width="28" Height="4" Margin="0,0,3,0" CornerRadius="2">
                                                <Border.Background>
                                                    <MultiBinding Converter="{StaticResource StrengthCellBrush}">
                                                        <Binding Path="PasswordStrength" />
                                                        <Binding Source="{StaticResource Idx1}" />
                                                    </MultiBinding>
                                                </Border.Background>
                                            </Border>
                                            <Border Width="28" Height="4" Margin="0,0,3,0" CornerRadius="2">
                                                <Border.Background>
                                                    <MultiBinding Converter="{StaticResource StrengthCellBrush}">
                                                        <Binding Path="PasswordStrength" />
                                                        <Binding Source="{StaticResource Idx2}" />
                                                    </MultiBinding>
                                                </Border.Background>
                                            </Border>
                                            <Border Width="28" Height="4" Margin="0,0,3,0" CornerRadius="2">
                                                <Border.Background>
                                                    <MultiBinding Converter="{StaticResource StrengthCellBrush}">
                                                        <Binding Path="PasswordStrength" />
                                                        <Binding Source="{StaticResource Idx3}" />
                                                    </MultiBinding>
                                                </Border.Background>
                                            </Border>
                                            <Border Width="28" Height="4" Margin="0,0,3,0" CornerRadius="2">
                                                <Border.Background>
                                                    <MultiBinding Converter="{StaticResource StrengthCellBrush}">
                                                        <Binding Path="PasswordStrength" />
                                                        <Binding Source="{StaticResource Idx4}" />
                                                    </MultiBinding>
                                                </Border.Background>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="{Binding PasswordLength}"
                                                       FontFamily="{DynamicResource Font.Mono}" FontSize="10.5"
                                                       Foreground="{DynamicResource Brush.Muted}" />
                                            <TextBlock Text=" chars · entropy ≈ "
                                                       FontFamily="{DynamicResource Font.Mono}" FontSize="10.5"
                                                       Foreground="{DynamicResource Brush.Muted}" />
                                            <TextBlock Text="{Binding PasswordEntropyBits}"
                                                       FontFamily="{DynamicResource Font.Mono}" FontSize="10.5"
                                                       Foreground="{DynamicResource Brush.Muted}" />
                                            <TextBlock Text=" bits"
                                                       FontFamily="{DynamicResource Font.Mono}" FontSize="10.5"
                                                       Foreground="{DynamicResource Brush.Muted}" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- URL -->
                            <Border Style="{StaticResource Field.Card}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource Text.CaptionLabel}" Text="URL" />
                                        <Button Grid.Column="1" Style="{StaticResource Btn.Mini}" Command="{Binding OpenUrlCommand}">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Style="{StaticResource Icon12}"
                                                      Data="{StaticResource Icon.Open}"
                                                      Stroke="{DynamicResource Brush.Muted}" />
                                                <TextBlock Text="open" Margin="5,0,0,0" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                    <TextBox Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
                                             Background="Transparent" BorderThickness="0" Padding="0"
                                             FontFamily="{DynamicResource Font.Mono}" FontSize="13"
                                             Foreground="{DynamicResource Brush.Link}" />
                                </StackPanel>
                            </Border>

                            <!-- Category -->
                            <Border Style="{StaticResource Field.Card}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Text.CaptionLabel}" Text="CATEGORY" Margin="0,0,0,6" />
                                    <ComboBox ItemsSource="{Binding Categories}"
                                              SelectedValuePath="Id"
                                              DisplayMemberPath="Name"
                                              SelectedValue="{Binding CategoryId}" />
                                </StackPanel>
                            </Border>

                            <!-- Notes -->
                            <Border Style="{StaticResource Field.Card}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Text.CaptionLabel}" Text="NOTES" Margin="0,0,0,6" />
                                    <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True" TextWrapping="Wrap"
                                             MinHeight="60" VerticalScrollBarVisibility="Auto"
                                             Background="Transparent" BorderThickness="0" Padding="0"
                                             FontSize="13" Foreground="{DynamicResource Brush.Text2}" />
                                </StackPanel>
                            </Border>

                            <!-- Custom fields -->
                            <Border Style="{StaticResource Field.Card}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource Text.CaptionLabel}" Text="CUSTOM FIELDS" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Style="{StaticResource Btn.Mini}" Command="{Binding AddFieldCommand}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Style="{StaticResource Icon12}" Data="{StaticResource Icon.Plus}" Stroke="{DynamicResource Brush.Muted}" />
                                                    <TextBlock Text="field" Margin="5,0,0,0" />
                                                </StackPanel>
                                            </Button>
                                            <Button Style="{StaticResource Btn.Mini}" Command="{Binding AddSecretFieldCommand}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Style="{StaticResource Icon12}" Data="{StaticResource Icon.Plus}" Stroke="{DynamicResource Brush.Muted}" />
                                                    <TextBlock Text="secret" Margin="5,0,0,0" />
                                                </StackPanel>
                                            </Button>
                                            <Button Style="{StaticResource Btn.Mini}" Command="{Binding AddSshTemplateCommand}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Style="{StaticResource Icon12}" Data="{StaticResource Icon.Plus}" Stroke="{DynamicResource Brush.Muted}" />
                                                    <TextBlock Text="ssh preset" Margin="5,0,0,0" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding CustomFields}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,3">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="160" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox Grid.Column="0"
                                                             Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                                             Background="Transparent" BorderThickness="0" Padding="0,4,0,0"
                                                             FontFamily="{DynamicResource Font.Mono}" FontSize="11.5"
                                                             Foreground="{DynamicResource Brush.Muted}"
                                                             VerticalAlignment="Top" />
                                                    <TextBox Grid.Column="1"
                                                             Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                             Background="{DynamicResource Brush.Panel2}"
                                                             FontFamily="{DynamicResource Font.Mono}" FontSize="12.5"
                                                             Margin="8,0,8,0"
                                                             AcceptsReturn="True"
                                                             TextWrapping="Wrap"
                                                             MinLines="1" MaxLines="12"
                                                             VerticalScrollBarVisibility="Auto">
                                                        <TextBox.Style>
                                                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                                <Style.Triggers>
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding IsSecret}" Value="True" />
                                                                            <Condition Binding="{Binding IsRevealed}" Value="False" />
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter Property="Foreground" Value="Transparent" />
                                                                    </MultiDataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBox.Style>
                                                    </TextBox>
                                                    <Button Grid.Column="2" Style="{StaticResource Btn.Mini}" Command="{Binding ToggleRevealCommand}"
                                                            Visibility="{Binding IsSecret, Converter={StaticResource BoolToVis}}"
                                                            VerticalAlignment="Top" Margin="0,2,0,0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Path Style="{StaticResource Icon12}" Data="{StaticResource Icon.Eye}" Stroke="{DynamicResource Brush.Muted}" />
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Grid.Column="3" Style="{StaticResource Btn.Mini}" Command="{Binding CopyCommand}"
                                                            VerticalAlignment="Top" Margin="0,2,0,0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Path Style="{StaticResource Icon12}" Data="{StaticResource Icon.Copy}" Stroke="{DynamicResource Brush.Muted}" />
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Grid.Column="4" Style="{StaticResource Btn.Mini}" Command="{Binding RemoveCommand}" ToolTip="Remove field"
                                                            VerticalAlignment="Top" Margin="0,2,0,0">
                                                        <Path Style="{StaticResource Icon12}" Data="{StaticResource Icon.X}" Stroke="{DynamicResource Brush.Accent}" />
                                                    </Button>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </StackPanel>

                    <!-- Empty state -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding HasEntry, Converter={StaticResource InverseBoolToVis}}">
                        <TextBlock Text="$" Foreground="{DynamicResource Brush.Accent}"
                                   FontFamily="{DynamicResource Font.Mono}" FontSize="13" Margin="0,0,6,0" />
                        <TextBlock Text="select or add an entry to view details_"
                                   Foreground="{DynamicResource Brush.Muted}"
                                   FontFamily="{DynamicResource Font.Mono}" FontSize="13" />
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- ═══════ Generator footer ═══════ -->
        <Border Grid.Row="2"
                Height="56"
                Background="{DynamicResource Brush.Panel}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="0,1,0,0">
            <Grid Margin="14,0" VerticalAlignment="Center" DataContext="{Binding Generator}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />  <!-- $ gen -->
                    <ColumnDefinition Width="Auto" />  <!-- len + slider -->
                    <ColumnDefinition Width="Auto" />  <!-- charset chips -->
                    <ColumnDefinition Width="*" />     <!-- output box (fills) -->
                    <ColumnDefinition Width="Auto" />  <!-- Regen + Use -->
                </Grid.ColumnDefinitions>

                <!-- $ gen — both 11px mono, baseline-aligned -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,14,0" VerticalAlignment="Center">
                    <TextBlock Text="$" Foreground="{DynamicResource Brush.Accent}"
                               FontFamily="{DynamicResource Font.Mono}" FontSize="11" Margin="0,0,6,0" />
                    <TextBlock Text="gen" Foreground="{DynamicResource Brush.Muted}"
                               FontFamily="{DynamicResource Font.Mono}" FontSize="11" />
                </StackPanel>

                <!-- length -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,14,0" VerticalAlignment="Center">
                    <TextBlock Text="len" FontFamily="{DynamicResource Font.Mono}" FontSize="11"
                               Foreground="{DynamicResource Brush.Muted}" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBox Text="{Binding Length, UpdateSourceTrigger=PropertyChanged}"
                             Width="46" FontSize="12"
                             FontFamily="{DynamicResource Font.Mono}"
                             HorizontalContentAlignment="Center"
                             Padding="0,2"
                             VerticalAlignment="Center" />
                    <Slider Minimum="8" Maximum="64" Value="{Binding Length, Mode=TwoWay}"
                            Width="100" Margin="8,0,0,0" VerticalAlignment="Center" />
                </StackPanel>

                <!-- charset chips -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,14,0" VerticalAlignment="Center">
                    <ToggleButton Style="{StaticResource Btn.Chip}" IsChecked="{Binding IncludeUppercase}" Content="A-Z" Margin="0,0,4,0" />
                    <ToggleButton Style="{StaticResource Btn.Chip}" IsChecked="{Binding IncludeLowercase}" Content="a-z" Margin="0,0,4,0" />
                    <ToggleButton Style="{StaticResource Btn.Chip}" IsChecked="{Binding IncludeDigits}"    Content="0-9" Margin="0,0,4,0" />
                    <ToggleButton Style="{StaticResource Btn.Chip}" IsChecked="{Binding IncludeSymbols}"   Content="!@#" Margin="0,0,4,0" />
                    <ToggleButton Style="{StaticResource Btn.Chip}" IsChecked="{Binding ExcludeAmbiguous}" Content="no-ambig" />
                </StackPanel>

                <!-- Output box (fills remaining space) -->
                <Border Grid.Column="3"
                        Background="{DynamicResource Brush.Bg}"
                        BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1"
                        CornerRadius="6" Height="32" Padding="10,0,6,0" VerticalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="›" Foreground="{DynamicResource Brush.Accent}"
                                   FontFamily="{DynamicResource Font.Mono}" FontSize="14"
                                   VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Grid.Column="1" Text="{Binding GeneratedPassword}"
                                   FontFamily="{DynamicResource Font.Mono}" FontSize="13"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        <Button Grid.Column="2" Style="{StaticResource Btn.Mini}"
                                Command="{Binding CopyCommand}"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Path Style="{StaticResource Icon12}" Data="{StaticResource Icon.Copy}"
                                      Stroke="{DynamicResource Brush.Muted}" />
                                <TextBlock Text="copy" Margin="5,0,0,0" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!-- Regen + Use -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="8,0,0,0" VerticalAlignment="Center">
                    <Button Style="{StaticResource Btn.Ghost}" Command="{Binding GenerateCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource Icon12}" Data="{StaticResource Icon.Refresh}"
                                  Stroke="{DynamicResource Brush.Text2}" />
                            <TextBlock Text="Regen" Margin="6,0,0,0" Foreground="{DynamicResource Brush.Text2}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource Btn.Primary}" Content="Use" MinWidth="60" Margin="4,0,0,0"
                            Command="{Binding DataContext.UseGeneratedPasswordCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
