<Window x:Class="PasswordKeeper.App.Views.PreferencesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Preferences"
        Icon="pack://application:,,,/Resources/Icons/PasswordKeeper.ico"
        SizeToContent="Height"
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource Brush.Bg}">
    <Border Background="{DynamicResource Brush.Panel}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="10"
            Margin="12"
            Padding="22,18,22,18">
        <StackPanel>
            <TextBlock Style="{StaticResource Text.Title}" FontSize="16" Text="Preferences" Margin="0,0,0,16" />

            <!-- ───── Global hotkey ───── -->
            <Border Style="{StaticResource Field.Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource Text.CaptionLabel}" Text="GLOBAL HOTKEY" Margin="0,0,0,8" />
                    <TextBlock Foreground="{DynamicResource Brush.Muted}" FontSize="11"
                               Text="Wakes the app from the system tray. Requires at least one modifier."
                               Margin="0,0,0,10" TextWrapping="Wrap" />

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <CheckBox IsChecked="{Binding HotkeyCtrl}"  Content="Ctrl"  Margin="0,0,12,0"
                                  Foreground="{DynamicResource Brush.Text}" />
                        <CheckBox IsChecked="{Binding HotkeyAlt}"   Content="Alt"   Margin="0,0,12,0"
                                  Foreground="{DynamicResource Brush.Text}" />
                        <CheckBox IsChecked="{Binding HotkeyShift}" Content="Shift" Margin="0,0,12,0"
                                  Foreground="{DynamicResource Brush.Text}" />
                        <CheckBox IsChecked="{Binding HotkeyWin}"   Content="Win"
                                  Foreground="{DynamicResource Brush.Text}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="key" FontFamily="{DynamicResource Font.Mono}" FontSize="11"
                                   Foreground="{DynamicResource Brush.Muted}" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <ComboBox ItemsSource="{Binding AvailableKeys}"
                                  SelectedItem="{Binding SelectedKey}"
                                  Width="100" />
                        <Border Background="{DynamicResource Brush.Panel2}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1" CornerRadius="6"
                                Margin="14,0,0,0" Padding="10,4" VerticalAlignment="Center">
                            <TextBlock Text="{Binding HotkeyPreview}"
                                       FontFamily="{DynamicResource Font.Mono}" FontSize="12"
                                       Foreground="{DynamicResource Brush.Accent}" />
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ───── Auto-lock ───── -->
            <Border Style="{StaticResource Field.Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource Text.CaptionLabel}" Text="AUTO-LOCK" Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Lock vault after" Foreground="{DynamicResource Brush.Text2}"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBox Text="{Binding IdleLockMinutes, UpdateSourceTrigger=PropertyChanged}"
                                 Width="60" HorizontalContentAlignment="Center" />
                        <TextBlock Text="minutes of inactivity" Foreground="{DynamicResource Brush.Text2}"
                                   VerticalAlignment="Center" Margin="8,0,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ───── Clipboard ───── -->
            <Border Style="{StaticResource Field.Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource Text.CaptionLabel}" Text="CLIPBOARD AUTO-CLEAR" Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Clear copied secret after" Foreground="{DynamicResource Brush.Text2}"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBox Text="{Binding ClipboardClearSeconds, UpdateSourceTrigger=PropertyChanged}"
                                 Width="60" HorizontalContentAlignment="Center" />
                        <TextBlock Text="seconds" Foreground="{DynamicResource Brush.Text2}"
                                   VerticalAlignment="Center" Margin="8,0,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ───── Startup ───── -->
            <Border Style="{StaticResource Field.Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource Text.CaptionLabel}" Text="STARTUP" Margin="0,0,0,8" />
                    <CheckBox IsChecked="{Binding LaunchAtStartup}"
                              Content="Launch PasswordKeeper when I sign in to Windows"
                              Foreground="{DynamicResource Brush.Text}" />
                    <TextBlock Foreground="{DynamicResource Brush.Muted}" FontSize="11"
                               Text="Starts minimized to the system tray and locked. Use the global hotkey or tray icon to open it."
                               Margin="24,6,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource Brush.Accent}"
                       FontSize="11.5" Margin="0,4,0,8" TextWrapping="Wrap" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Style="{StaticResource Btn.Default}" Content="Cancel" MinWidth="90"
                        IsCancel="True" Command="{Binding CancelCommand}" Margin="0,0,8,0" />
                <Button Style="{StaticResource Btn.Primary}" Content="Save" MinWidth="90"
                        IsDefault="True" Command="{Binding SaveCommand}" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
