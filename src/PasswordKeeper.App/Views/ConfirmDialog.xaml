<Window x:Class="PasswordKeeper.App.Views.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm"
        Icon="pack://application:,,,/Resources/Icons/PasswordKeeper.ico"
        SizeToContent="Height"
        Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource Brush.Bg}">
    <Border Background="{DynamicResource Brush.Panel}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="10"
            Margin="12"
            Padding="22,18,22,18">
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Border Width="28" Height="28" CornerRadius="6"
                        Background="{DynamicResource Brush.AccentSoft}"
                        BorderBrush="{DynamicResource Brush.AccentEdge}"
                        BorderThickness="1"
                        Margin="0,0,12,0">
                    <Path Stretch="Uniform" Width="14" Height="14"
                          Data="{StaticResource Icon.Trash}"
                          Stroke="{DynamicResource Brush.Accent}"
                          StrokeThickness="1.5"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round" />
                </Border>
                <TextBlock x:Name="TitleText"
                           Style="{StaticResource Text.Title}"
                           FontSize="16"
                           VerticalAlignment="Center"
                           Text="Confirm" />
            </StackPanel>

            <TextBlock x:Name="MessageText"
                       Foreground="{DynamicResource Brush.Text2}"
                       FontSize="13"
                       TextWrapping="Wrap"
                       Margin="0,0,0,20" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelBtn"
                        Style="{StaticResource Btn.Default}"
                        Content="Cancel"
                        MinWidth="90"
                        IsCancel="True"
                        Click="OnCancel"
                        Margin="0,0,8,0" />
                <Button x:Name="ConfirmBtn"
                        Style="{StaticResource Btn.Primary}"
                        Content="Delete"
                        MinWidth="90"
                        IsDefault="True"
                        Click="OnConfirm" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
