<Window x:Class="PasswordKeeper.App.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PasswordKeeper"
        Icon="pack://application:,,,/Resources/Icons/PasswordKeeper.ico"
        Width="460" Height="340"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource Brush.Bg}">
    <Border Background="{DynamicResource Brush.Panel}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="10"
            Margin="14"
            Padding="28">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Logo row -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                <Image Source="pack://application:,,,/Resources/Icons/PasswordKeeper-32.png"
                       Width="28" Height="28" Margin="0,0,10,0" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="passwordkeeper"
                               FontFamily="{DynamicResource Font.Mono}" FontSize="16" FontWeight="Medium"
                               Foreground="{DynamicResource Brush.Text}" />
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <TextBlock Text="/ " Foreground="{DynamicResource Brush.Dim}"
                                   FontFamily="{DynamicResource Font.Mono}" FontSize="11" />
                        <TextBlock Text="vault.local" Foreground="{DynamicResource Brush.Muted}"
                                   FontFamily="{DynamicResource Font.Mono}" FontSize="11" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <TextBlock Grid.Row="1"
                       Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource Brush.Text2}"
                       Margin="0,18,0,12"
                       TextWrapping="Wrap" />

            <TextBlock Grid.Row="2" Style="{StaticResource Text.CaptionLabel}" Text="MASTER PASSWORD" Margin="0,0,0,6" />
            <PasswordBox Grid.Row="3" x:Name="PasswordBox" />

            <StackPanel Grid.Row="4" Visibility="{Binding IsCreateMode, Converter={StaticResource BoolToVis}}" Margin="0,12,0,0">
                <TextBlock Style="{StaticResource Text.CaptionLabel}" Text="CONFIRM PASSWORD" Margin="0,0,0,6" />
                <PasswordBox x:Name="ConfirmPasswordBox" />
            </StackPanel>

            <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button x:Name="SubmitButton"
                        Style="{StaticResource Btn.Primary}"
                        Content="Unlock"
                        Click="OnSubmitClick"
                        MinWidth="120"
                        IsDefault="True"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
